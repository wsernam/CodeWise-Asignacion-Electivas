		{
			"name": "1. Pick first Programa (set {{proCodigo}})",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"200 OK\", function () { pm.response.to.have.status(200); });",
							"let data = pm.response.json();",
							"if (Array.isArray(data) && data.length > 0) {",
							"  let first = data[0];",
							"  let id = first.pro_codigo || first.id || first.pk;",
							"  pm.collectionVariables.set('proCodigo', id);",
							"  pm.test('proCodigo seteado', function(){ pm.expect(!!id).to.eql(true); });",
							"} else if (data && data.results && data.results.length > 0) {",
							"  let first = data.results[0];",
							"  let id = first.pro_codigo || first.id || first.pk;",
							"  pm.collectionVariables.set('proCodigo', id);",
							"  pm.test('proCodigo seteado (paginated)', function(){ pm.expect(!!id).to.eql(true); });",
							"} else {",
							"  pm.test('No hay programas: crea uno antes de seguir', function(){ pm.expect(false).to.eql(true); });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/programas/",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"programas",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Crear Estudiante (éxito)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Genera correo único por ejecución",
							"const ts = Date.now();",
							"const email = `estudiante.${ts}@example.com`;",
							"pm.collectionVariables.set('studentEmail', email);"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('201 creado', function () { pm.response.to.have.status(201); });",
							"const body = pm.response.json();",
							"pm.collectionVariables.set('estudianteId', body.est_codigo || body.id || body.pk);",
							"pm.test('Tiene est_correo', function () { pm.expect(body).to.have.property('est_correo'); });",
							"pm.test('FK pro_codigo presente', function () { pm.expect(body).to.have.property('pro_codigo'); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"est_nombre\": \"{{$randomFirstName}}\",\n  \"est_apellido\": \"{{$randomLastName}}\",\n  \"est_correo\": \"{{studentEmail}}\",\n  \"pro_codigo\": {{proCodigo}},\n  \"est_activo\": true\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/estudiantes/",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"estudiantes",
						""
					]
				}
			},
			"response": []
		},
