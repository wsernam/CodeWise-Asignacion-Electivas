							"let j = pm.response.json();",
							"pm.test('Mensaje de correo duplicado', function(){",
							"  const msg = JSON.stringify(j).toLowerCase();",
							"  pm.expect(msg.includes('correo') || msg.includes('est_correo') || msg.includes('unique')).to.eql(true);",
							"});"
						],
						"type": "text/javascript"
					}
				}
