		{
			"name": "6.1-1 Crear programa (éxito)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('201 creado', () => pm.response.code === 201);",
							"const body = pm.response.json();",
							"pm.environment.set('programaId', body.pro_codigo);",
							"pm.test('tiene nombre/facultad', () => body.pro_nombre && body.fac_codigo);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
