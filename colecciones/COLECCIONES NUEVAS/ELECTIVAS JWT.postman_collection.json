	"item": [
		{
			"name": "obtener token Asignador",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const jsonData = pm.response.json();\r",
							"\r",
							"// Si la respuesta trae el access token, lo guardamos\r",
							"if (jsonData.access) {\r",
							"    pm.environment.set(\"token\", jsonData.access);\r",
							"}"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"username\": \"asignador\",\r\n    \"password\": \"contraseña_asignador\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:8000/auth/login/api/login/",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"auth",
						"login",
						"api",
						"login",
						""
					]
				}
			},
			"response": []
